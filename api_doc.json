{
  "api_documentation": {
    "project": "BiliLiveNotifier",
    "version": "1.0.0",
    "description": "Bilibili 直播状态监控与提醒核心 API 接口文档。返回体仅列出实际所需，并不代表全部返回。接口随时可能变动。版本号策略采用 SemVer 。",
    "endpoints": [
      {
        "id": "get-user-info",
        "name": "用户空间信息获取（含生日与直播间基础信息）",
        "description": "通过用户 UID (mid) 获取用户个人空间信息，包含生日、昵称、头像、直播间 ID 及简化直播状态。此接口在程序启动时调用一次，用于缓存用户画像和直播间 ID。",
        "http_method": "GET",
        "base_url": "https://api.bilibili.com/x/space/acc/info",
        "request_parameters": [
          {
            "name": "mid",
            "type": "integer (int64)",
            "required": true,
            "description": "目标用户的 Bilibili UID。"
          }
        ],
        "response_schema": {
          "code": {
            "type": "integer",
            "description": "API 响应状态码：0-成功，-799-风控加扰需重试，-400-请求错误，-403-权限不足，-404-用户不存在。"
          },
          "data": {
            "type": "object",
            "description": "响应数据主体。",
            "properties": {
              "mid": {
                "type": "integer (int64)",
                "description": "用户 UID，用于数据校验。"
              },
              "name": {
                "type": "string",
                "description": "用户昵称。"
              },
              "face": {
                "type": "string",
                "description": "用户头像 URL。"
              },
              "birthday": {
                "type": "string",
                "description": "用户生日，格式 MM-DD（如 04-28）。若用户设置隐私则返回空字符串。"
              },
              "silence": {
                "type": "integer",
                "description": "封禁状态：0-正常，1-被封。"
              },
              "live_room": {
                "type": "object",
                "description": "直播间简化信息模块。",
                "properties": {
                  "roomStatus": {
                    "type": "integer",
                    "description": "直播间状态：0-无房间，1-有房间。"
                  },
                  "liveStatus": {
                    "type": "integer",
                    "description": "直播状态：0-未开播，1-直播中。"
                  },
                  "roomid": {
                    "type": "integer (int64)",
                    "description": "直播间 ID（长号），用于后续调用直播间详情接口。"
                  },
                  "title": {
                    "type": "string",
                    "description": "直播间标题（可能延迟，建议以 GetLiveRoomDetail 为准）。"
                  },
                  "cover": {
                    "type": "string",
                    "description": "直播间封面图 URL（可能延迟，建议以 GetLiveRoomDetail 为准）。"
                  },
                  "url": {
                    "type": "string",
                    "description": "直播间网页 URL。"
                  },
                  "watched_show": {
                    "type": "object",
                    "properties": {
                      "num": {
                        "type": "integer",
                        "description": "看过本直播的总人数（历史累计，非实时在线）。"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "风控及鉴权": "无"
      },
      {
        "id": "get-master-info",
        "name": "主播详细信息获取（含粉丝勋章）",
        "description": "通过用户 UID 获取主播详细信息，包含粉丝勋章名称（medal_name）。此接口在程序启动时调用一次，用于缓存粉丝勋章等静态信息。",
        "http_method": "GET",
        "base_url": "https://api.live.bilibili.com/live_user/v1/Master/info",
        "request_parameters": [
          {
            "name": "uid",
            "type": "integer (int64)",
            "required": true,
            "description": "目标用户的 Bilibili UID。"
          }
        ],
        "response_schema": {
          "code": {
            "type": "integer",
            "description": "API 响应状态码：0-成功，1-参数错误。"
          },
          "data": {
            "type": "object",
            "description": "响应数据主体。",
            "properties": {
              "info": {
                "type": "object",
                "description": "主播基本信息模块。",
                "properties": {
                  "uid": {
                    "type": "integer (int64)",
                    "description": "主播 UID。"
                  },
                  "uname": {
                    "type": "string",
                    "description": "主播昵称。"
                  },
                  "face": {
                    "type": "string",
                    "description": "主播头像 URL。"
                  }
                }
              },
              "room_id": {
                "type": "integer (int64)",
                "description": "直播间 ID（若有短号则为短号，否则为长号）。"
              },
              "medal_name": {
                "type": "string",
                "description": "粉丝勋章名称（若无粉丝勋章则为空字符串）。"
              }
            }
          }
        },
        "风控及鉴权": "无"
      },
      {
        "id": "get-live-room-detail",
        "name": "直播间实时详情（轮询核心接口）",
        "description": "获取直播间的实时详细信息，包含直播状态、在线人数、分区、标题、开播时间等。此接口为高频轮询核心数据源，在监控周期内反复调用以检测开播状态变化。",
        "http_method": "GET",
        "base_url": "https://api.live.bilibili.com/room/v1/Room/get_info",
        "request_parameters": [
          {
            "name": "room_id",
            "type": "integer (int64)",
            "required": true,
            "description": "直播间 ID，支持长短号（由 GetUserInfo 或 GetMasterInfo 获取）。"
          }
        ],
        "response_schema": {
          "code": {
            "type": "integer",
            "description": "API 响应状态码：0-成功，1-房间不存在。"
          },
          "data": {
            "type": "object",
            "description": "响应数据主体。",
            "properties": {
              "uid": {
                "type": "integer (int64)",
                "description": "主播 UID。"
              },
              "room_id": {
                "type": "integer (int64)",
                "description": "直播间长号。"
              },
              "short_id": {
                "type": "integer (int64)",
                "description": "直播间短号，若为 0 则无短号。"
              },
              "online": {
                "type": "integer",
                "description": "当前实时观看人数。"
              },
              "live_status": {
                "type": "integer",
                "description": "直播状态：0-未开播，1-直播中，2-轮播中。"
              },
              "parent_area_name": {
                "type": "string",
                "description": "父分区名称（如：虚拟主播、游戏）。"
              },
              "area_name": {
                "type": "string",
                "description": "子分区名称（如：虚拟日常、主机游戏）。"
              },
              "title": {
                "type": "string",
                "description": "当前直播间标题。"
              },
              "user_cover": {
                "type": "string",
                "description": "当前直播间封面图 URL。"
              },
              "live_time": {
                "type": "string",
                "description": "本次开播开始时间，格式 YYYY-MM-DD HH:mm:ss，未直播时为 0000-00-00 00:00:00。"
              }
            }
          }
        },
        "风控及鉴权": "无"
      }
    ],
    "implementation_notes": {
      "data_flow": "1. 初始化：调用 GetUserInfo 和 GetMasterInfo，分别获取用户画像（含生日、头像、昵称、房间 ID）和粉丝勋章，缓存至内存。\n2. 轮询监控：使用缓存中的 room_id，高频调用 GetLiveRoomDetail（建议间隔：未开播时 10~15 秒，开播后 30~60 秒）。\n3. 触发条件：检测 live_status 从 0 变为 1 时触发开播提醒。\n4. 特殊提醒：当系统日期与用户生日（MM-DD）匹配时触发生日提醒。",
      "deserialization": "建议在 C# 中使用 System.Text.Json，并配合 JsonPropertyName 特性映射上述字段，未定义的字段将被自动忽略以优化内存。",
      "deprecated_endpoints": [
        {
          "id": "get-live-room-info",
          "reason": "风控过于严格，需要有效 buvid3 且未激活的 buvid3 无法通过风控，已放弃使用。"
        }
      ]
    }
  }
}